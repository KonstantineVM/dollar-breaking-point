import json, html, re, collections
import pyarrow.parquet as pq, pyarrow.compute as pc
PANEL='build/data/nport/us_china_nationality_panel.parquet'
hf_conc = json.load(open('build/data/crosswalk/hfcaa/hfcaa_conclusive.json'))
ct = json.load(open('build/data/crosswalk/hfcaa/company_tickers.json'))
ct_by_cik=collections.defaultdict(set)
for it in ct.values(): ct_by_cik[int(it['cik_str'])].add(it['title'])

SUFFIX=re.compile(r'\b(INCORPORATED|INC|CORPORATION|CORP|LIMITED|LTD|LLC|LP|PLC|CO|COMPANY|GROUP|HOLDINGS|HOLDING|GMBH|AG|SA|NV|ADR|ADS|SPONSORED|UNSPONSORED|THE)\b')
def norm(s):
    if not s: return ''
    s=html.unescape(s).replace('\xa0',' ').upper()
    s=re.sub(r'[^A-Z0-9 ]',' ',s); s=SUFFIX.sub(' ',s)
    return re.sub(r'\s+',' ',s).strip()
def stem(s):
    s=html.unescape(s or '').replace('\xa0',' ').upper(); s=re.sub(r'[^A-Z0-9 ]',' ',s)
    return s.split()[0] if s.split() else ''

t=pq.read_table(PANEL, columns=['issuer_name','cusip','isin','issuer_lei','currency_value','is_haven_resident'])
t=t.filter(pc.equal(t['is_haven_resident'],True))
nm=t['issuer_name'].to_pylist(); cu=t['cusip'].to_pylist(); isin=t['isin'].to_pylist(); lei=t['issuer_lei'].to_pylist(); val=t['currency_value'].to_pylist()
pname_idx=collections.defaultdict(list)
for i,x in enumerate(nm): pname_idx[norm(x)].append(i)

# candidates = HFCAA decoded name + company_tickers titles sharing HFCAA stem
hf_norms={}
for r in hf_conc:
    cik=int(r['cik']); hstem=stem(r['issuer_name'])
    cands={norm(r['issuer_name'])}
    for ttl in ct_by_cik.get(cik,[]):
        if stem(ttl)==hstem: cands.add(norm(ttl))
    cands.discard(''); hf_norms[cik]=cands
matched_rows={}
for cik,cands in hf_norms.items():
    rows=[]
    for c in cands: rows+=pname_idx.get(c,[])
    matched_rows[cik]=sorted(set(rows))
prior=json.load(open('build/data/crosswalk/hfcaa/hfcaa_panel_match.json'))
prior_matched=set(int(x['cik']) for x in prior if x['matched'])
newly=[c for c in hf_norms if matched_rows[c] and c not in prior_matched]
print('matched CIKs (restricted):', sum(1 for c in matched_rows if matched_rows[c]))
print('newly matched:', len(newly))
tv=0.0; tr=0
for cik in sorted(newly):
    rows=matched_rows[cik]; v=sum(val[i] or 0 for i in rows); tv+=v; tr+=len(rows)
    print(f'  CIK {cik:>9} rows={len(rows):>5} value={v:>16.0f}  hf={[r["issuer_name"] for r in hf_conc if int(r["cik"])==cik][0]!r}')
print('newly rows',tr,'value',tv)
# also report identifiers each newly matched CIK resolves to
print()
print('=== resolved identifiers for newly matched (CIK -> cusip6/isin/lei) ===')
for cik in sorted(newly):
    rows=matched_rows[cik]
    c6=sorted(set((cu[i] or '')[:6] for i in rows if cu[i]) - {'','000000'})
    iss=sorted(set(isin[i] for i in rows if isin[i]))
    le=sorted(set(lei[i] for i in rows if lei[i] and lei[i]!='N/A'))
    print(f'  CIK {cik}: cusip6={c6} isin={iss} lei={le}')
