    g=nh.groupby(['holder','fiscal_quarter']).agg(cn=('cn','sum'),tot=(col,'sum')).reset_index()
    g=g[g.tot>0]; g['w']=g.cn/g.tot; return g[['holder','fiscal_quarter','w']]
m=wp('usd').merge(wp('raw'),on=['holder','fiscal_quarter'],suffixes=('_u','_r'))
# WITHIN-FUND demean both, compare the within variation (that's what identifies beta)
for c in ['w_u','w_r']:
    m[c+'_dm']=m[c]-m.groupby('holder')[c].transform('mean')
dd=(m.w_u_dm-m.w_r_dm).abs()
print('within-fund demeaned w: FX vs raw mean abs diff',dd.mean(),'p95',dd.quantile(.95),'max',dd.max())
print('SD within w_u',m.w_u_dm.std(),'SD within w_r',m.w_r_dm.std())
print('corr within:',np.corrcoef(m.w_u_dm,m.w_r_dm)[0,1])
PY
