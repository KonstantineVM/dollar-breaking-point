python3 << 'EOF'
import json, numpy as np

D='build/data/'
bis=json.load(open(D+'bis_lbs/lbs_compact.json'))
tic=json.load(open(D+'treasury_tic/mfh_dec2025.json'))
cofer=json.load(open(D+'imf_cofer/cofer_marginal.json'))
fed=json.load(open(D+'fed_z1/fwtw_2026Q1.json'))

# BIS lookup
bm={}
for r in bis['rows']: bm[(r['denom'],r['position'],r['cp_country'])]=r['value_usd_mn']

# ---- ASSEMBLE: area x area USD cross-border CLAIM matrix (creditor area -> debtor area), I1+I2 ----
areas=['US','CN','JP','GB','DE','FR','KY','HK','SG','CH','LU','IE','NL','BE','CA','KR','AU','IN','BR']
n=len(areas); idx={a:i for i,a in enumerate(areas)}

# Seed: we have, per counterparty area, BIS all-reporting-banks USD CLAIMS on that area (=area's USD bank liability)
# and USD LIABILITIES to that area (=area's USD bank claim). These are area marginals vs the WORLD of reporting banks,
# not area-x-area bilateral. The only true area-x-area bilateral USD cell obtainable is US-Treasury: TIC gives
# (counterparty area -> US government) holdings.
# Build a seed from the structure we can defend:
#   row = creditor area (holds the claim), col = debtor area (owes)
# Observed bilateral entries:
tic_map={'China, Mainland':'CN','Japan':'JP','United Kingdom':'GB','Cayman Islands':'KY','Hong Kong':'HK',
         'Belgium':'BE','Luxembourg':'LU','Switzerland':'CH','Ireland':'IE','Canada':'CA','Korea':'KR',
         'Singapore':'SG','Brazil':'BR','India':'IN','France':'FR','Germany':'DE','Netherlands':'NL','Australia':'AU'}
seed=np.zeros((n,n))
observed_mask=np.zeros((n,n),bool)
# TIC: counterparty area holds US Treasuries => creditor=area, debtor=US  (in USD bn -> convert to mn)
for name,v in tic['holdings'].items():
    if name in tic_map and tic_map[name] in idx:
        a=idx[tic_map[name]]; u=idx['US']
        seed[a,u]+= v*1000.0  # bn -> mn
        observed_mask[a,u]=True
# BIS USD claims ON area = banks (resident in reporting countries) hold claim on that area.
# Treat as creditor=ROW-bank-system, debtor=area. We cannot place a single creditor area, so we use BIS
# as a COLUMN MARGINAL (total USD liability of each area to the global bank system), and BIS USD liabilities
# TO area as a ROW MARGINAL (total USD claim of each area on the global bank system).
col_marg=np.zeros(n)  # USD liability of debtor area (sum over creditors) -> from BIS USD claims on area
row_marg=np.zeros(n)  # USD claim of creditor area -> from BIS USD liabilities to area
for a in areas:
    col_marg[idx[a]]=bm.get(('USD','C',a),0.0)   # claims ON a  = a's liability
    row_marg[idx[a]]=bm.get(('USD','L',a),0.0)   # liabilities TO a = a's claim
print('Assembled seed nonzero (observed bilateral USD-Treasury) cells:', int(observed_mask.sum()))
print('Row marginal (USD claims, BIS) total $mn:', round(row_marg.sum(),1))
print('Col marginal (USD liabilities, BIS) total $mn:', round(col_marg.sum(),1))

# ---- BALANCE: RAS / Sinkhorn ----
# Seed must be nonnegative and have support where marginals are nonzero. Where seed row/col is empty but
# marginal nonzero, RAS cannot create mass from a zero row. Add a minimal uniform prior ONLY to rows/cols
# that have a positive marginal but zero seed, and FLAG those as estimated-by-prior (not observed).
seed_for_ras=seed.copy()
prior_added=np.zeros((n,n),bool)
eps=1.0  # $1mn uniform prior to enable RAS where a marginal exists but seed is empty
for i in range(n):
    if seed_for_ras[i,:].sum()==0 and row_marg[i]>0:
        seed_for_ras[i,:]=eps; prior_added[i,:]=True
for j in range(n):
    if seed_for_ras[:,j].sum()==0 and col_marg[j]>0:
        seed_for_ras[:,j]=eps; prior_added[:,j]=True
# avoid self-loops dominating: keep diagonal as is
A=seed_for_ras.copy()
passes=[]
maxpass=200; tol=1e-6
r_target=row_marg.copy(); c_target=col_marg.copy()
# scale targets to common total (RAS requires sum(row)=sum(col)); report the imbalance as a structural residual
tot_r=r_target.sum(); tot_c=c_target.sum()
total_imbalance=tot_r-tot_c
# Use the average total as the consistent grand total; rescale both marginals proportionally
G=(tot_r+tot_c)/2.0
r_t=r_target*(G/tot_r); c_t=c_target*(G/tot_c)
for p in range(maxpass):
    # row scale
    rs=A.sum(1); rs[rs==0]=1
    A=A*(r_t/rs)[:,None]
    # col scale
    cs=A.sum(0); cs[cs==0]=1
    A=A*(c_t/cs)[None,:]
    row_res=np.abs(A.sum(1)-r_t)
    col_res=np.abs(A.sum(0)-c_t)
    passes.append({'pass':p+1,'row_resid_L2':float(np.linalg.norm(row_res)),
                   'col_resid_L2':float(np.linalg.norm(col_res)),
                   'row_resid_Linf':float(row_res.max()),'col_resid_Linf':float(col_res.max())})
    if max(row_res.max(),col_res.max())<tol*G:
        break
print('RAS passes to converge:',len(passes))
print('final row L2',passes[-1]['row_resid_L2'],'col L2',passes[-1]['col_resid_L2'])

# Where do largest residuals concentrate?
row_res=A.sum(1)-r_t; col_res=A.sum(0)-c_t
row_rank=sorted([(areas[i],float(row_res[i])) for i in range(n)],key=lambda x:-abs(x[1]))[:5]
col_rank=sorted([(areas[j],float(col_res[j])) for j in range(n)],key=lambda x:-abs(x[1]))[:5]

np.save('/tmp/A_balanced.npy',A)
json.dump({'areas':areas,'passes':passes,'row_rank':row_rank,'col_rank':col_rank,
           'observed_bilateral_cells':int(observed_mask.sum()),
           'prior_seeded_cells':int(prior_added.sum()),
           'marginal_imbalance_row_minus_col_USD_mn':float(total_imbalance),
           'grand_total_used_USD_mn':float(G),
           'row_marg_total':float(tot_r),'col_marg_total':float(tot_c)},
          open('/tmp/ras_out.json','w'),indent=1)
print('OK')
EOF
