import json, pandas as pd, numpy as np
# recompute LOQO + wild bootstrap deterministically and append to result json (traceable)
df=pd.read_parquet('build/data/cm_panel/cm_weight_panel.parquet')
QUARTERS=['2019q3','2019q4','2020q1','2020q2','2020q3','2022q1','2022q2','2024q4']
QORD={q:i for i,q in enumerate(QUARTERS)}; df['qord']=df['fiscal_quarter'].map(QORD)
CTRL=['log_vix','broad_dollar','oil','relative_returns']
def add_lags(d,wcol):
    look={(h,o):v for h,o,v in zip(d['holder'],d['qord'],d[wcol])}
    d=d.copy()
    d['L1']=[look.get((h,o-1),np.nan) for h,o in zip(d['holder'],d['qord'])]
    d['L2']=[look.get((h,o-2),np.nan) for h,o in zip(d['holder'],d['qord'])]
    return d
def within_beta(d,wcol,gcol,rhs):
    d=d.dropna(subset=[wcol]+rhs).copy()
    cnt=d.groupby('holder')['holder'].transform('size'); d=d[cnt>=2]
    if d['holder'].nunique()<2: return None,0
    for c in [wcol]+rhs: d[c+'_w']=d[c]-d.groupby('holder')[c].transform('mean')
    y=d[wcol+'_w'].to_numpy(); X=d[[c+'_w' for c in rhs]].to_numpy()
    b,*_=np.linalg.lstsq(X,y,rcond=None); return float(b[rhs.index(gcol)]),len(d)
rhs=['gprc_avg','L1','L2']+CTRL; dl=add_lags(df,'w')
b_full,_=within_beta(dl,'w','gprc_avg',rhs)
loqo={q: within_beta(dl[dl['fiscal_quarter']!=q],'w','gprc_avg',rhs)[0] for q in QUARTERS}

# wild bootstrap (no-lags, G=8) deterministic seed
rhs2=['gprc_avg']+CTRL
