import csv, json
# Fed FWTW 2026Q1: aggregate over instruments -> holder x issuer sector matrix (US block), and keep Rest of World cells
period='2026Q1'
cells={}  # (holder,issuer)->level (sum over instruments)
rowtot={}; coltot={}
holders=set(); issuers=set()
with open('fed_z1/fwtw_data.csv') as f:
    for r in csv.DictReader(f):
        if r['Date']!=period: continue
        h=r['Holder Name']; i=r['Issuer Name']
        try: v=float(r['Level'])
        except: continue
        holders.add(h); issuers.add(i)
        cells[(h,i)]=cells.get((h,i),0)+v
        rowtot[h]=rowtot.get(h,0)+v
        coltot[i]=coltot.get(i,0)+v
# Rest of World as holder (foreign holdings of US instruments) and as issuer
row_n=len(holders); col_n=len(issuers)
print('Fed FWTW',period,'holders',row_n,'issuers',col_n,'nonzero cells',sum(1 for v in cells.values() if v!=0))
print('RoW as holder (foreign holdings of US-issued, $mn):', round(rowtot.get('Rest of World',0),1))
print('RoW as issuer (US holdings of foreign-issued, $mn):', round(coltot.get('Rest of World',0),1))
# save compact
out={'source':'Fed Z.1 EFA from-whom-to-whom','period':period,'unit':'USD millions','basis':'residency','note':'estimated issuer-to-holder; corporate equities excluded per publisher',
     'holder_sectors':sorted(holders),'issuer_sectors':sorted(issuers),
     'cells':[{'holder':h,'issuer':i,'level':round(v,3)} for (h,i),v in cells.items() if v!=0],
     'holder_totals':{k:round(v,3) for k,v in rowtot.items()},
     'issuer_totals':{k:round(v,3) for k,v in coltot.items()}}
json.dump(out, open('fed_z1/fwtw_2026Q1.json','w'))
print('wrote fed_z1/fwtw_2026Q1.json, cells:',len(out['cells']))
EOF
